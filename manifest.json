{
  "manifest_version": 3,
  "name": "My Reader View",
  "version": "1.2.0",
  "description": "Clean reading experience for any webpage",
  "action": {
    "default_title": "Toggle Reader View"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
